{
  "manifest_version": 3,
  "name": "SafeMail-X Phishing Detector",
  "version": "1.1",
  "description": "Detect phishing emails using SafeMail-X AI engine",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],

  "action": {
    "default_popup": "popup.html"
  }
}